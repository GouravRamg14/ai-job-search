# Copy to .env and fill in. Never commit .env.

# Session / JWT (use long random strings in production)
FLASK_SECRET_KEY=change-me
JWT_SECRET_KEY=change-me

# Frontend URL for Google OAuth redirect after login
FRONTEND_URL=http://localhost:5173

# Public URL of this Flask app (OAuth redirect_uri). Must match Google Console.
BACKEND_URL=http://127.0.0.1:5000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI must include:
#   http://127.0.0.1:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
